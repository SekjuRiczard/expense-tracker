# Public HTTP port exposed by the production web container.
HTTP_PORT=80

# MySQL
DB_NAME=expense_tracker
DB_USER=expense_user
DB_PASSWORD=change_me_db_user_password
DB_ROOT_PASSWORD=change_me_db_root_password

# Symfony
APP_SECRET=change_me_symfony_app_secret

# JWT
JWT_PASSPHRASE=change_me_jwt_passphrase

# CORS
# For same-origin Nginx proxy this is not critical, but keep it configured.
# For a real domain, replace this with a stricter regex, e.g. ^https://app\.example\.com$
CORS_ALLOW_ORIGIN=^https?://.*$

# Cookies
# false for plain http://IP demo
# true when you use real HTTPS domain
AUTH_COOKIE_SECURE=false

# Mailer
# null://null disables real email sending for demo deployment.
MAILER_DSN=null://null
MAILER_FROM=no-reply@example.com

# Frontend build-time env
VITE_API_URL=/api
VITE_API_TIMEOUT_MS=10000

# Set to 1 only when you intentionally want migrations to run on container start.
RUN_MIGRATIONS=0