# Copy the secret values into a gitignored .env.local (development) or .env.test (tests),
# or provide them through real environment variables (production / CI). Never commit real secrets.
APP_ENV=dev
APP_SECRET=

# Database
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_TEST_NAME=
DB_TEST_PORT=
DATABASE_URL=

# JWT (lexik/jwt-authentication-bundle)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

# CORS (nelmio/cors-bundle)
CORS_ALLOW_ORIGIN=

# Lock (symfony/lock)
LOCK_DSN=flock

# Auth cookies: must be true in production so cookies are only sent over HTTPS.
AUTH_COOKIE_SECURE=false

# Mailer (symfony/mailer)
MAILER_DSN=
MAILER_FROM=
